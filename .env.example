# Copy this file to `.env` in the project root and replace the placeholder values.
# Profile, search filters, schedule, AI model and API key are configured in the panel.

# Runtime
JOB_APPLIER_DATA_DIR=artifacts/runtime
JOB_APPLIER_OUTPUT_DIR=artifacts/last-run
JOB_APPLIER_BACKEND_HOST=0.0.0.0
JOB_APPLIER_BACKEND_PORT=8000
JOB_APPLIER_PANEL_PORT=3000
JOB_APPLIER_PLAYWRIGHT_MCP_URL=http://localhost:8931/mcp
JOB_APPLIER_PLAYWRIGHT_MCP_HOST=localhost
JOB_APPLIER_PLAYWRIGHT_MCP_PORT=8931
JOB_APPLIER_PLAYWRIGHT_MCP_PREFER_STDIO_FOR_LOCAL=true
# JOB_APPLIER_PLAYWRIGHT_MCP_STDIO_COMMAND=npx -y @playwright/mcp@latest
JOB_APPLIER_SCHEDULER_POLL_INTERVAL_SECONDS=30
JOB_APPLIER_AGENT_TEST_MODE=false
JOB_APPLIER_AGENT_DEBUG_STAGE=full

# Database
# Leave empty to use the local SQLite fallback inside `artifacts/runtime/job-applier.db`.
# Example external DB:
# JOB_APPLIER_DATABASE_URL=postgresql+psycopg://user:pass@host/dbname
JOB_APPLIER_DATABASE_URL=

# Playwright / browser
JOB_APPLIER_PLAYWRIGHT_HEADLESS=false
JOB_APPLIER_PLAYWRIGHT_TRACE_ENABLED=true
JOB_APPLIER_STAGEHAND_ENABLED=false
# Linux host display example for visible browser:
# DISPLAY=:0
# For local testing outside Docker, you can run:
# npx @playwright/mcp@latest --port 8931
# If JOB_APPLIER_PLAYWRIGHT_MCP_URL is empty in Docker, the entrypoint starts a local Playwright MCP sidecar.
# Optional Stagehand semantic extraction:
# JOB_APPLIER_STAGEHAND_ENABLED=true
# JOB_APPLIER_STAGEHAND_LOCAL_CHROME_PATH=
# JOB_APPLIER_STAGEHAND_CACHE_DIR=artifacts/runtime/stagehand-cache

# LinkedIn
JOB_APPLIER_LINKEDIN_EMAIL=you@example.com
JOB_APPLIER_LINKEDIN_PASSWORD=replace-with-your-linkedin-password
JOB_APPLIER_LINKEDIN_MAX_SEARCH_PAGES=4
JOB_APPLIER_LINKEDIN_DEBUG_TARGET_JOB_URL=
JOB_APPLIER_LINKEDIN_DEFAULT_TIMEOUT_MS=15000
JOB_APPLIER_LINKEDIN_LOGIN_TIMEOUT_SECONDS=120
JOB_APPLIER_LINKEDIN_MIN_ACTION_DELAY_MS=350
JOB_APPLIER_LINKEDIN_MAX_ACTION_DELAY_MS=950
JOB_APPLIER_LINKEDIN_MIN_NAVIGATION_DELAY_MS=800
JOB_APPLIER_LINKEDIN_MAX_NAVIGATION_DELAY_MS=1800

# Optional local bootstrap to skip manual onboarding when panel state is empty.
# The app will try to detect a CV/resume in ~/Documents automatically, but you can pin it here.
# OPENAI_API_KEY=sk-your-openai-key
# JOB_APPLIER_BOOTSTRAP_PROFILE_CITY=SAO PAULO - SP BRASIL
# JOB_APPLIER_BOOTSTRAP_PROFILE_CV_PATH=/home/thiago/Documents/Thiago Martins - CV 2026.pdf
# JOB_APPLIER_BOOTSTRAP_PROFILE_LINKEDIN_URL=https://www.linkedin.com/in/your-profile
# JOB_APPLIER_BOOTSTRAP_PROFILE_PHONE=+5511999999999

# Optional custom paths
# JOB_APPLIER_OUTPUT_DIR=artifacts/last-run
# JOB_APPLIER_PANEL_STORAGE_DIR=artifacts/runtime/panel
# JOB_APPLIER_LINKEDIN_STORAGE_STATE_PATH=artifacts/runtime/linkedin/storage-state.json
# JOB_APPLIER_LINKEDIN_ARTIFACTS_DIR=artifacts/runtime/artifacts/linkedin
# JOB_APPLIER_LOG_LEVEL=INFO
# JOB_APPLIER_LOG_JSON=true
# JOB_APPLIER_LOG_FILE_PATH=artifacts/runtime/logs/job-applier.log
# JOB_APPLIER_OPENAI_RESPONSES_MAX_RETRIES=2
# JOB_APPLIER_OPENAI_RESPONSES_RETRY_MAX_DELAY_SECONDS=20
# JOB_APPLIER_BROWSER_AGENT_SINGLE_ACTION_MAX_ATTEMPTS=3
# JOB_APPLIER_BROWSER_AGENT_STALL_THRESHOLD=3
# JOB_APPLIER_LINKEDIN_FIELD_INTERACTION_TIMEOUT_SECONDS=45
# JOB_APPLIER_AGENT_MAX_SELECTED_JOBS_PER_RUN=1
# JOB_APPLIER_AGENT_TEST_MINIMUM_SCORE_THRESHOLD=0.50
# JOB_APPLIER_AGENT_DEBUG_STAGE=search
# JOB_APPLIER_AGENT_DEBUG_MAX_JOBS=3

# Test mode for cheaper/manual debugging:
# - only 1 selected job is processed per run
# - OpenAI HTTP retries are disabled
# - browser reasoning still uses as many steps as needed inside the task budget
# - stall diagnosis logs help explain where the agent stopped making progress
# - optional score-threshold override helps force one near-match through the pipeline
# JOB_APPLIER_AGENT_TEST_MODE=true

# Optional staged debug flow:
# - `search` stops after fetch/hydration so you can validate titles, companies and filters
# - `score` fetches and scores a few jobs without entering Easy Apply
# - `apply` keeps the run focused on one selected job
# - `full` keeps the normal end-to-end behavior
# JOB_APPLIER_AGENT_DEBUG_STAGE=search
# JOB_APPLIER_AGENT_DEBUG_MAX_JOBS=3

JOB_APPLIER_OPENAI_API_KEY=sk-your-openai-key
