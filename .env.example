# Copy this file to `.env` in the project root and replace the placeholder values.
# Profile, search filters, schedule, AI model and API key are configured in the panel.

# Runtime
JOB_APPLIER_DATA_DIR=artifacts/runtime
JOB_APPLIER_BACKEND_HOST=0.0.0.0
JOB_APPLIER_BACKEND_PORT=8000
JOB_APPLIER_PANEL_PORT=3000
JOB_APPLIER_SCHEDULER_POLL_INTERVAL_SECONDS=30

# Database
# Leave empty to use the local SQLite fallback inside `artifacts/runtime/job-applier.db`.
# Example external DB:
# JOB_APPLIER_DATABASE_URL=postgresql+psycopg://user:pass@host/dbname
JOB_APPLIER_DATABASE_URL=

# Playwright / browser
JOB_APPLIER_PLAYWRIGHT_HEADLESS=false
# Linux host display example for visible browser:
# DISPLAY=:0

# LinkedIn
JOB_APPLIER_LINKEDIN_EMAIL=you@example.com
JOB_APPLIER_LINKEDIN_PASSWORD=replace-with-your-linkedin-password
JOB_APPLIER_LINKEDIN_MAX_SEARCH_PAGES=2
JOB_APPLIER_LINKEDIN_DEFAULT_TIMEOUT_MS=15000
JOB_APPLIER_LINKEDIN_LOGIN_TIMEOUT_SECONDS=120

# Optional custom paths
# JOB_APPLIER_PANEL_STORAGE_DIR=artifacts/runtime/panel
# JOB_APPLIER_LINKEDIN_STORAGE_STATE_PATH=artifacts/runtime/linkedin/storage-state.json
# JOB_APPLIER_LINKEDIN_ARTIFACTS_DIR=artifacts/runtime/artifacts/linkedin
